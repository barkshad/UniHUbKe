{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (landlord, student, or admin).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "landlord", "admin"] },
        "favorites": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["id", "email", "role", "createdAt"]
    },
    "Listing": {
      "title": "Listing",
      "description": "A property listing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["hostel", "apartment", "bedsitter"] },
        "location": { "type": "string" },
        "coordinates": { 
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "images": { "type": "array", "items": { "type": "string" } },
        "landlordId": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "contactWhatsapp": { "type": "string" },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["available", "rented"] },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "title", "description", "price", "type", "location", "images", "landlordId", "createdAt", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "listings/{listingId}": {
      "schema": "Listing",
      "description": "Property listings"
    }
  }
}
